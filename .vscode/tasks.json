{
    "version": "2.0.0",
    "tasks": [
        // ── Upload everything ──────────────────────────────────────────────
        // Rocket and base station run in parallel.
        // Base station sequence: compress -> firmware -> (sleep) -> LittleFS
        {
            "label": "Upload All",
            "dependsOn": ["Upload: rocket", "Upload: base_station + LittleFS"],
            "dependsOrder": "parallel",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Rocket ─────────────────────────────────────────────────────────
        {
            "label": "Upload: rocket",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe",
            "args": ["run", "-e", "rocket", "-t", "upload"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },

        // ── Base station ───────────────────────────────────────────────────
        // Steps run in sequence: compress -> firmware -> sleep -> LittleFS
        {
            "label": "Upload: base_station + LittleFS",
            "dependsOn": [
                "Compress web assets",
                "Upload: base_station firmware",
                "Wait for COM9",
                "Upload: base_station LittleFS"
            ],
            "dependsOrder": "sequence",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Compress web assets",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "base_station/compress_web.ps1"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Upload: base_station firmware",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe",
            "args": ["run", "-e", "base_station", "-t", "upload"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            // Port takes a few seconds to reappear after firmware reset
            "label": "Wait for COM9",
            "type": "shell",
            "command": "Start-Sleep",
            "args": ["-Seconds", "4"],
            "presentation": { "reveal": "silent", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Upload: base_station LittleFS",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe",
            "args": ["run", "-e", "base_station", "-t", "uploadfs"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },

        // ── Individual tasks (run from Command Palette if needed) ──────────
        {
            "label": "Build: rocket",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe",
            "args": ["run", "-e", "rocket"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Build: base_station",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe",
            "args": ["run", "-e", "base_station"],
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Monitor: rocket (COM13)",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe",
            "args": ["device", "monitor", "-e", "rocket"],
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        },
        {
            "label": "Monitor: base_station (COM9)",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe",
            "args": ["device", "monitor", "-e", "base_station"],
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        }
    ]
}
