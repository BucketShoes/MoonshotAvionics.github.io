{
    "version": "2.0.0",
    "tasks": [
        // ── Upload everything ──────────────────────────────────────────────
        // Compresses web assets, then uploads firmware + LittleFS to base
        // station and firmware to rocket. Both boards attempted regardless
        // of whether the other succeeds.
        {
            "label": "Upload All",
            "dependsOn": ["Upload: rocket", "Upload: base_station + LittleFS"],
            "dependsOrder": "parallel",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" }
        },

        // ── Rocket ─────────────────────────────────────────────────────────
        {
            "label": "Upload: rocket",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe run -e rocket -t upload",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },

        // ── Base station ───────────────────────────────────────────────────
        // Compress web assets first, then upload firmware + LittleFS.
        {
            "label": "Upload: base_station + LittleFS",
            "dependsOn": ["Compress web assets", "Upload: base_station firmware"],
            "dependsOrder": "sequence",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Compress web assets",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File base_station/compress_web.ps1",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Upload: base_station firmware",
            "type": "shell",
            // Upload firmware, wait 3s for the port to recover, then upload LittleFS.
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe run -e base_station -t upload && Start-Sleep 3 && ${userHome}/.platformio/penv/Scripts/pio.exe run -e base_station -t uploadfs",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },

        // ── Individual tasks (run from Command Palette if needed) ──────────
        {
            "label": "Build: rocket",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe run -e rocket",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Build: base_station",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe run -e base_station",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Monitor: rocket (COM13)",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe device monitor -e rocket",
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        },
        {
            "label": "Monitor: base_station (COM9)",
            "type": "shell",
            "command": "${userHome}/.platformio/penv/Scripts/pio.exe device monitor -e base_station",
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        }
    ]
}
